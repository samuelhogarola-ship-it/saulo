{
  "name": "saulo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node server.js",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "precommit": "lint-staged",
    "prepare": "husky",
    "playwright:install": "playwright install --with-deps chromium",
    "product:bootstrap:student": "node scripts/bootstrap-supabase-student.js",
    "product:bootstrap:trainer": "node scripts/bootstrap-supabase-trainer.js",
    "product:check": "node scripts/check-product-setup.js",
    "product:contract:delivery": "node scripts/print-magic-link-provider-contract.js",
    "product:handoff:go-live": "node scripts/export-delivery-go-live-checklist.js",
    "product:handoff:delivery": "node scripts/export-magic-link-provider-handoff.js",
    "product:check:templates": "node scripts/check-student-templates.js",
    "product:mock:delivery": "node scripts/mock-magic-link-provider.js",
    "product:smoke:delivery": "node scripts/smoke-magic-link-delivery.js",
    "product:smoke:supabase": "node scripts/smoke-supabase-product.js",
    "start": "node server.js",
    "test": "npm run test:e2e",
    "test:e2e": "node scripts/run-e2e.js",
    "test:e2e:ui": "playwright test --ui"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.1",
    "http-server": "^14.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "prettier": "^3.6.2"
  },
  "dependencies": {
    "express": "^5.1.0"
  },
  "lint-staged": {
    "*.{html,css,js,json,md,ts,yml,yaml}": "prettier --write"
  }
}
