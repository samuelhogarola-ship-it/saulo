PORT=4173

# Core runtime
SAULO_DATA_MODE=local
DEFAULT_STUDENT_ACCESS_TOKEN=lucia-access
TRAINER_API_TOKEN=local-trainer-token
TRAINER_LOGIN_EMAIL=local@saulofitness.app
TRAINER_LOGIN_PASSWORD=saulo1234

# Magic link delivery
MAGIC_LINK_WEBHOOK_URL=
MAGIC_LINK_SENDER_NAME=Coach Saulo
MAGIC_LINK_WEBHOOK_TIMEOUT_MS=5000
MAGIC_LINK_WEBHOOK_SECRET=
MAGIC_LINK_WEBHOOK_SIGNATURE_HEADER=x-saulo-signature
MAGIC_LINK_WEBHOOK_BEARER_TOKEN=

# Local mock provider / delivery smoke
MOCK_MAGIC_LINK_PROVIDER_PORT=8787
MOCK_MAGIC_LINK_PROVIDER_HOST=127.0.0.1
MOCK_MAGIC_LINK_PROVIDER_OUTPUT_PATH=.tmp/magic-link-last.json
DELIVERY_SMOKE_APP_PORT=4317
DELIVERY_SMOKE_PROVIDER_PORT=8788
DELIVERY_SMOKE_PROVIDER_HOST=127.0.0.1
DELIVERY_SMOKE_OUTPUT_PATH=

# Supabase delivery handoff samples
PROVIDER_CONTRACT_ORIGIN=https://saulofitness.com
PROVIDER_CONTRACT_WAITING_ROOM_TOKEN=waiting-room-sample-123
PROVIDER_CONTRACT_ACCESS_TOKEN=student-access-sample-123
PROVIDER_CONTRACT_STUDENT_ID=student-sample-001
PROVIDER_CONTRACT_STUDENT_NAME=Lucia Ortega
PROVIDER_CONTRACT_PLAN=Definicion
PROVIDER_CONTRACT_CONTACT_EMAIL=lucia@saulofitness.app
PROVIDER_CONTRACT_CONTACT_PHONE=+34600000001

# Product mode (required for real product)
# Set SAULO_DATA_MODE=supabase to activate the real product data layer.
# If these values are missing or placeholders, the app will warn and fall back to local mode.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_PROGRESS_PHOTOS_BUCKET=progress-photos
DELIVERY_GO_LIVE_OUTPUT_PATH=docs/delivery-go-live-checklist.md
DELIVERY_HANDOFF_OUTPUT_PATH=docs/provider-magic-link-handoff.md
PRODUCT_ENV_TEMPLATE_OUTPUT_PATH=docs/product-env-template.env

# Bootstrap trainer (recommended before first real smoke)
BOOTSTRAP_TRAINER_EMAIL=trainer@saulofitness.com
BOOTSTRAP_TRAINER_PASSWORD=change-me
BOOTSTRAP_TRAINER_NAME=Saulo Trainer
BOOTSTRAP_ADOPT_UNASSIGNED_STUDENTS=false

# Bootstrap first student
BOOTSTRAP_TRAINER_ID=
BOOTSTRAP_STUDENT_TEMPLATE_PATH=
BOOTSTRAP_STUDENT_NAME=Lucia Ortega
BOOTSTRAP_STUDENT_CONTACT_EMAIL=lucia@saulofitness.app
BOOTSTRAP_STUDENT_CONTACT_PHONE=+34600000001
BOOTSTRAP_STUDENT_PLAN=Definicion
BOOTSTRAP_STUDENT_GOAL=Bajar grasa y mantener fuerza
BOOTSTRAP_STUDENT_AGE=31 anos
BOOTSTRAP_STUDENT_WEIGHT=63,4 kg
BOOTSTRAP_STUDENT_SUMMARY=Solo tu marcas tus limites.
BOOTSTRAP_STUDENT_PROFILE_NOTE_TITLE=Adherencia alta con feedback rapido
BOOTSTRAP_STUDENT_PROFILE_NOTE=Prefiere instrucciones claras y seguimiento breve despues de cada sesion.
BOOTSTRAP_STUDENT_ACCESS_TOKEN=
BOOTSTRAP_STUDENT_PLAN_LABEL=Plan 30 dias
BOOTSTRAP_STUDENT_VALID_UNTIL=
BOOTSTRAP_STUDENT_PLAN_END=
BOOTSTRAP_STUDENT_NEXT_PHOTO_DUE_AT=

# Supabase product smoke
SMOKE_TRAINER_EMAIL=trainer@saulofitness.com
SMOKE_TRAINER_PASSWORD=change-me
SMOKE_STUDENT_ID=
SMOKE_STUDENT_CONTACT_EMAIL=lucia@saulofitness.app
SMOKE_STUDENT_NAME=
SMOKE_STUDENT_ACCESS_TOKEN=
SMOKE_STUDENT_DAY=1
SMOKE_TRIGGER_WAITING_ROOM=false

# Minimal real-product activation checklist:
# 1. Set SAULO_DATA_MODE=supabase
# 2. Fill SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY with real values
# 3. Set BOOTSTRAP_TRAINER_* and run npm run product:bootstrap:trainer
# 4. Set BOOTSTRAP_STUDENT_* or BOOTSTRAP_STUDENT_TEMPLATE_PATH and run npm run product:bootstrap:student
# 5. Set SMOKE_TRAINER_* and run npm run product:smoke:supabase
# 6. Set MAGIC_LINK_WEBHOOK_URL to your Supabase Edge Function URL and run npm run product:smoke:delivery
# Optional helper: npm run product:env:template
# Optional helper when credentials already exist in .env: npm run product:env:activate-supabase
